extends Node3D

@onready var order_popup = $CanvasLayer/Order_PopUp
@onready var env_back = $CanvasLayer/Order_PopUp/EnvelopeBack
@onready var env_front = $CanvasLayer/Order_PopUp/EnvelopeFront
@onready var letter = $CanvasLayer/Order_PopUp/LetterContainer
@onready var start_button = $CanvasLayer/Start_Button
@onready var ready_button = $CanvasLayer/Ready_Button
@onready var timer_label = $CanvasLayer/Order_PopUp/LetterContainer/LetterPaper/Timer

@export var cabinet: Node3D
@export var total_time: float = 10.0

var time_left: float
var is_timer_active: bool = false
var is_game_started: bool = false

func _ready():
	start_button.pressed.connect(_on_start_pressed)
	ready_button.pressed.connect(_on_ready_pressed)
	_reset_ui()

func _reset_ui():
	ready_button.modulate.a = 0.0
	ready_button.hide()
	env_back.modulate.a = 0.0
	env_front.modulate.a = 0.0
	letter.modulate.a = 0.0
	if cabinet: cabinet.hide()

func _process(delta):
	if is_timer_active and time_left > 0:
		time_left -= delta
		timer_label.text = str(ceil(time_left)) + "s"
		if time_left <= 0: _on_timer_timeout()

func _on_start_pressed():
	start_button.hide()
	ItemManager.generate_new_order()
	order_popup.fill_order_icons()
	
	time_left = total_time
	is_game_started = false
	_animate_intro()

func _animate_intro():
	order_popup.position.y = 2300
	letter.position.y = -2000
	letter.scale.y = 0.1
	
	var tw = create_tween().set_parallel(true)
	tw.tween_property(order_popup, "position:y", 1800, 1.0).set_trans(Tween.TRANS_CIRC).set_ease(Tween.EASE_OUT)
	tw.tween_property(env_back, "modulate:a", 1.0, 0.2)
	tw.tween_property(env_front, "modulate:a", 1.0, 0.2)
	
	tw.tween_property(letter, "position:y", 500, 0.5).set_delay(0.3).set_trans(Tween.TRANS_CIRC)
	tw.tween_property(letter, "scale:y", 1.0, 0.5).set_delay(0.3)
	tw.tween_property(letter, "modulate:a", 1.0, 0.2).set_delay(0.3)
	
	await tw.finished
	ready_button.show()
	create_tween().tween_property(ready_button, "modulate:a", 1.0, 0.2)
	is_timer_active = true

func _on_ready_pressed():
	if is_game_started: return
	is_timer_active = false
	start_game_flow()

func _on_timer_timeout():
	if is_game_started: return
	start_game_flow()

func start_game_flow():
	is_game_started = true
	ready_button.disabled = true
	if cabinet: cabinet.build_cabinet_tornado()
	_animate_outro()

func _animate_outro():
	var tw = create_tween().set_parallel(true)
	tw.tween_property(order_popup, "position:y", 2300, 0.8).set_trans(Tween.TRANS_CIRC).set_ease(Tween.EASE_IN)
	tw.tween_property(letter, "modulate:a", 0.0, 0.3)
	tw.tween_property(ready_button, "modulate:a", 0.0, 0.3)
	tw.chain().tween_callback(ready_button.hide)